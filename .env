# ===============================
# Gin 服务基础配置
# ===============================

# Gin 运行模式
# 可选值：debug / release / test
# 开发阶段建议 debug，线上部署建议 release
GIN_MODE=release

# HTTP 服务监听地址
# :2077 表示监听所有网卡的 2077 端口
# 也可以写成 127.0.0.1:2077
SERVER_ADDR=:2077


# ===============================
# JWT 身份认证相关配置
# ===============================

# JWT 签名密钥（非常重要）
# 用于生成和校验 Token
# 生产环境请使用足够复杂、不可泄露的字符串
JWT_SECRET=HereIsYourStrongSecret

# JWT 签发者（issuer）
# 用于标识 Token 是由哪个系统签发的
# 一般是项目名或服务名
JWT_ISSUER=gin-backend

# JWT 过期时间（单位：小时）
# 例如 24 表示 Token 有效期为 24 小时
JWT_EXPIRE_HOURS=24

# JWT 自动续签阈值（单位：小时）
# 当 Token 剩余有效时间 < 该值 时，接口响应头会返回新 Token
# 前端可从响应头 X-Refresh-Token 中读取
JWT_REFRESH_THRESHOLD_HOURS=6


# ===============================
# 数据库配置
# ===============================

# 数据库驱动类型
# 可选值：sqlite / mysql
DB_DRIVER=sqlite

# 数据库连接字符串（DSN）
# sqlite 示例：./db/hr.db
DB_DSN=./db/hr.db

# mysql 示例：user:password@tcp(127.0.0.1:3306)/dbname?charset=utf8mb4&parseTime=True
#DB-DSN=user:123@tcp(localhost:3306)/hrdb?charset=utf8mb4&parseTime=True&loc=Local

# 是否开启 SQL 调试日志
# true  ：打印 SQL（开发调试用）
# false ：不打印（推荐线上）
DB_DEBUG=false


# ===============================
# 服务优雅退出
# ===============================

# 服务关闭超时时间（单位：秒）
# 收到 SIGTERM / Ctrl+C 后，最多等待这么久处理完请求再退出
SHUTDOWN_TIMEOUT_SECONDS=5
