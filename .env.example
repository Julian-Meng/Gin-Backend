# ====================================
# Application runtime (Go service)
# ====================================

# Gin mode: debug / release / test
GIN_MODE=release

# HTTP listen address
SERVER_ADDR=:2077

# Graceful shutdown timeout in seconds
SHUTDOWN_TIMEOUT_SECONDS=5

# ------------------------------------
# JWT
# ------------------------------------

# Required: server will exit if empty
JWT_SECRET=change_me_to_a_strong_secret
JWT_ISSUER=gin-backend
JWT_EXPIRE_HOURS=24
JWT_REFRESH_THRESHOLD_HOURS=6

# ------------------------------------
# Database
# ------------------------------------

# sqlite or mysql
DB_DRIVER=sqlite
DB_DEBUG=false

# SQLite DSN (default)
DB_DSN=./db/hr.db

# MySQL DSN example:
# DB_DSN=user:password@tcp(127.0.0.1:3306)/hrdb?charset=utf8mb4&parseTime=True&loc=Local

# ------------------------------------
# Superadmin
# ------------------------------------

# Required: must be explicit true/false
SUPERADMIN_ENABLED=false

# Required only when SUPERADMIN_ENABLED=true
SUPERADMIN_USERNAME=root
SUPERADMIN_PASSWORD=change_me_superadmin_password
# Allowed: superadmin/admin (case-insensitive)
SUPERADMIN_ROLE=superadmin

# ------------------------------------
# Account role change
# ------------------------------------

# Allowed: admin/superadmin (case-insensitive). Default: superadmin
ACCOUNT_ROLE_CHANGE_REQUIRED_ROLE=superadmin

# ------------------------------------
# Captcha
# ------------------------------------

LOGIN_CAPTCHA_THRESHOLD=3
CAPTCHA_TTL_SECONDS=180

# ------------------------------------
# AI chat
# ------------------------------------

AI_PROVIDER=ollama
AI_MODEL_ID=qwen3:4b
AI_BASE_URL=http://127.0.0.1:11434/v1
AI_API_KEY=
AI_SYSTEM_PROMPT=You are an enterprise HR assistant. Keep answers concise and avoid chain-of-thought output.

# ------------------------------------
# Support chat fallback
# ------------------------------------

CHAT_AI_FALLBACK_ENABLED=true
CHAT_AI_FALLBACK_MIN_GAP_SECONDS=30

# ------------------------------------
# Error response detail
# ------------------------------------

# Return error detail in JSON response when true.
# In GIN_MODE=debug, detail is also exposed by default.
ERROR_DETAIL_ENABLED=false

# ====================================
# Infrastructure (docker-compose)
# ====================================

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=hrdb
MYSQL_USER=user
MYSQL_PASSWORD=change_me_user_password
MYSQL_PORT=3306

OLLAMA_PORT=11434
