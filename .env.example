# ===============================
# Gin 服务基础配置
# ===============================

# Gin 运行模式
# 可选值：debug / release / test
# 开发阶段建议 debug，线上部署建议 release
GIN_MODE=release

# HTTP 服务监听地址
SERVER_ADDR=:2077


# ===============================
# JWT 身份认证相关配置
# ===============================

# JWT 签名密钥（非常重要）
JWT_SECRET=your_strong_jwt_secret_key

# JWT 签发者（issuer）
JWT_ISSUER=gin-backend

# JWT 过期时间（单位：小时）
JWT_EXPIRE_HOURS=24

# JWT 自动续签阈值（单位：小时）
JWT_REFRESH_THRESHOLD_HOURS=6

# ===============================
# Superadmin / Root 兜底账号（仅用于演示/紧急救援）
# ===============================

# 超级管理员用户名/密码/角色
SUPERADMIN_USERNAME=your_root_name
SUPERADMIN_PASSWORD=your_root_password
SUPERADMIN_ROLE=superadmin

# 是否启用 superadmin（建议生产环境关闭）
SUPERADMIN_ENABLED=true/false

# ===============================
# 数据库配置
# ===============================

# 数据库驱动类型
# 可选值：sqlite / mysql
DB_DRIVER=sqlite

# 数据库连接字符串（DSN）
# sqlite 示例：./db/hr.db
DB_DSN=./db/hr.db

# mysql 示例：user:password@tcp(127.0.0.1:3306)/dbname?charset=utf8mb4&parseTime=True

# 是否开启 SQL 调试日志
# true  ：打印 SQL（开发调试用）
# false ：不打印（推荐线上）
DB_DEBUG=false


# ===============================
# AI 模块配置
# ===============================

# AI 服务提供方
AI_PROVIDER=your_AI_provider

# 模型 ID
AI_MODEL_ID=your_AI_model_id

# 兼容接口基础 URL
AI_BASE_URL=your_AI_base_url

# 可留空
AI_API_KEY=your_AI_API_key_if_needed

# System Prompt
# 注意：如果你的 dotenv 解析器对换行不友好，就保持一行
AI_SYSTEM_PROMPT=write your system prompt here


# ===============================
# 服务退出配置
# ===============================

# 服务关闭超时时间（单位：秒）
SHUTDOWN_TIMEOUT_SECONDS=5
