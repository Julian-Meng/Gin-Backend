# ===============================
# Gin 服务基础配置
# ===============================

# Gin 运行模式
# 可选值：debug / release / test
# 开发阶段建议 debug，线上部署建议 release
GIN_MODE=release

# HTTP 服务监听地址
SERVER_ADDR=:2077

# ===============================
# JWT 身份认证相关配置
# ===============================

# JWT 签名密钥（非常重要）
JWT_SECRET=your_strong_jwt_secret_key

# JWT 签发者（issuer）
JWT_ISSUER=gin-backend

# JWT 过期时间（单位：小时）
JWT_EXPIRE_HOURS=24

# JWT 自动续签阈值（单位：小时）
JWT_REFRESH_THRESHOLD_HOURS=6

# ===============================
# Superadmin / Root 兜底账号（仅用于演示/紧急救援）
# ===============================

# 超级管理员用户名/密码/角色
SUPERADMIN_USERNAME=your_root_name
SUPERADMIN_PASSWORD=your_root_password
SUPERADMIN_ROLE=superadmin

# 是否启用 superadmin（建议生产环境关闭）
SUPERADMIN_ENABLED=false

# ===============================
# 远程连接相关配置
# ===============================

# MySQL 连接配置（供docker读取使用）
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=your_database_name
MYSQL_USER=your_database_user
MYSQL_PASSWORD=your_database_user_password
MYSQL_PORT=3306

# Go ORM 数据库配置
DB_DRIVER=sqlite#mysql/sqlite
DB_DEBUG=false#true/false
DB_HOST=127.0.0.1

# MySQL 
# DB_DSN=your_database_user:your_database_user_password@tcp(127.0.0.1:3306)/your_database_name?charset=utf8mb4&parseTime=True&loc=Local
# SQLite
DB_DSN=./db/hr.db

# Ollama LLM 服务配置
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ===============================
# AI 模块配置
# ===============================

# AI 服务提供方
AI_PROVIDER=your_AI_provider

# 模型 ID
AI_MODEL_ID=your_AI_model_id

# 兼容接口基础 URL
AI_BASE_URL=your_AI_base_url

# 可留空
AI_API_KEY=your_AI_API_key_if_needed

# System Prompt
# 注意：如果你的 dotenv 解析器对换行不友好，就保持一行
AI_SYSTEM_PROMPT='write your system prompt here'

# ===============================
# 聊天模块 AI 配置
# ===============================

# 是否启用“管理员离线时 AI 自动兜底回复”
CHAT_AI_FALLBACK_ENABLED=true

# 同一会话 AI 兜底的最小触发间隔（秒）
CHAT_AI_FALLBACK_MIN_GAP_SECONDS=30

# ===============================
# 服务退出配置
# ===============================

# 服务关闭超时时间（单位：秒）
SHUTDOWN_TIMEOUT_SECONDS=5
